 #
 # This file is the IDE-friendly, standalone mirror of the <stencil><twig>
 # block embedded inside modules/crowdaq-widget.xml. Xibo CMS reads the
 # inline copy from the XML manifest — when editing, change BOTH. A
 # release-packaging check (TODO: MVP-widget iter) will verify parity.
 #
 # Variables available at render time:
 #
 #   eventId           (string) — CROWDAQ event id, from manifest property
 #                                 of the same name. May be empty, in which
 #                                 case the backend picks the best event.
 #   refreshInterval   (int)    — fallback polling interval in seconds.
 #   theme             (string) — 'dark' | 'light'.
 #   showTeamLogos     (bool)   — whether to render team crest <img> tags.
 #   showLastMoment    (bool)   — whether to render the last-moment row.
 #   maxMomentLength   (int)    — truncate cap for the last-moment text;
 #                                 applied in JS in <onRender>.
 #
 # Data shape (applied to the DOM by the <onRender> JS in the manifest):
 #
 #   {
 #     "match_id":   "string",
 #     "event_id":   "string",
 #     "clock":      {"minute": int, "stoppage": int, "period": "1H|2H|HT|FT"},
 #     "score":      {"home": int, "away": int},
 #     "teams": {
 #       "home": {"name": "string", "abbreviation": "string", "logo_url": "string"},
 #       "away": {"name": "string", "abbreviation": "string", "logo_url": "string"}
 #     },
 #     "excitement": {"level": 0.0-1.0, "trend": "rising|falling|flat"},
 #     "last_moment": {
 #       "type":   "goal|card|var|penalty|substitution|kickoff|end|…",
 #       "team":   "home|away|neutral",
 #       "minute": int,
 #       "text":   "string"
 #     },
 #     "next_update_hint_ms": int
 #   }
 #
 # The full contract is documented in docs/ARCHITECTURE.md and declared
 # in datatypes/crowdaq-event.xml (consumed by Xibo's data-provider
 # registry via the <dataType> element in the manifest).
 #}
<div
    class="crowdaq-widget crowdaq-theme-{{ theme|default('dark') }}"
    data-crowdaq-event-id="{{ eventId|default('') }}"
    data-crowdaq-refresh-interval="{{ refreshInterval|default(30) }}"
    data-crowdaq-show-team-logos="{{ showTeamLogos|default(1) }}"
    data-crowdaq-show-last-moment="{{ showLastMoment|default(1) }}"
    data-crowdaq-max-moment-length="{{ maxMomentLength|default(80) }}">

    <div class="crowdaq-row crowdaq-row-score">
        {% if showTeamLogos %}
        <img class="crowdaq-team-logo crowdaq-team-logo-home" src="" alt="" />
        {% endif %}
        <span class="crowdaq-team-name crowdaq-team-name-home">Home</span>
        <span class="crowdaq-score crowdaq-score-home">0</span>
        <span class="crowdaq-score-divider">&ndash;</span>
        <span class="crowdaq-score crowdaq-score-away">0</span>
        <span class="crowdaq-team-name crowdaq-team-name-away">Away</span>
        {% if showTeamLogos %}
        <img class="crowdaq-team-logo crowdaq-team-logo-away" src="" alt="" />
        {% endif %}
    </div>

    <div class="crowdaq-row crowdaq-row-excitement">
        <div class="crowdaq-excitement-meter" role="progressbar" aria-valuemin="0" aria-valuemax="10" aria-valuenow="0">
            <div class="crowdaq-excitement-fill" style="width: 0%"></div>
        </div>
        <span class="crowdaq-excitement-value">0.0</span>
        <span class="crowdaq-excitement-trend" data-trend="flat">&bull;</span>
    </div>

    {% if showLastMoment %}
    <div class="crowdaq-row crowdaq-row-moment">
        <span class="crowdaq-moment-text">Waiting for CROWDAQ feed&hellip;</span>
    </div>
    {% endif %}

    <div class="crowdaq-status" data-state="connecting" aria-live="polite">connecting</div>
</div>
